<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:aio="http://aio-upgrade/schema/1.0" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_AIO_TwoWay_Sample" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.47.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Customer" name="Customer" />
    <bpmn:participant id="Participant_Order" name="Order Management System" processRef="Process_Order" />
    <bpmn:participant id="Participant_Warehouse" name="Warehouse / Inventory Service" />
    <bpmn:participant id="Participant_Payment" name="Payment Gateway" />
    <bpmn:messageFlow id="MessageFlow_Submit" name="Submit order" sourceRef="Participant_Customer" targetRef="StartEvent_OrderReceived" aio:animated="true" />
    <bpmn:messageFlow id="MessageFlow_Ship" name="Shipment notification" sourceRef="Task_Ship" targetRef="Participant_Customer" aio:animated="true" />
    <bpmn:messageFlow id="Flow_170ewdk" sourceRef="Task_Backorder" targetRef="Participant_Payment" aio:animated="true" aio:twoWay="true" />
    <bpmn:messageFlow id="Flow_1dyz5hw" sourceRef="Task_Reserve" targetRef="Participant_Warehouse" aio:animated="true" aio:twoWay="true" />
    <bpmn:group id="Group_12gj2fu" aio:background="true" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Order" isExecutable="false">
    <bpmn:laneSet id="LaneSet_0444kqz" />
    <bpmn:startEvent id="StartEvent_OrderReceived" name="Order received">
      <bpmn:outgoing>Flow_Start_Validate</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Validate" name="Validate Order">
      <bpmn:incoming>Flow_Start_Validate</bpmn:incoming>
      <bpmn:outgoing>Flow_Validate_GWValid</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Valid" name="Order valid?">
      <bpmn:incoming>Flow_Validate_GWValid</bpmn:incoming>
      <bpmn:outgoing>Flow_Valid_Reserve</bpmn:outgoing>
      <bpmn:outgoing>Flow_Valid_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_Rejected" name="Order rejected">
      <bpmn:incoming>Flow_Valid_Rejected</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Reserve" name="Reserve Inventory">
      <bpmn:incoming>Flow_Valid_Reserve</bpmn:incoming>
      <bpmn:outgoing>Flow_Reserve_GWStock</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Stock" name="In stock?">
      <bpmn:incoming>Flow_Reserve_GWStock</bpmn:incoming>
      <bpmn:outgoing>Flow_Stock_Payment</bpmn:outgoing>
      <bpmn:outgoing>Flow_Stock_Backorder</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Backorder" name="Create Backorder">
      <bpmn:incoming>Flow_Stock_Backorder</bpmn:incoming>
      <bpmn:outgoing>Flow_Backorder_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Payment" name="Process Payment">
      <bpmn:incoming>Flow_Stock_Payment</bpmn:incoming>
      <bpmn:outgoing>Flow_Payment_Ship</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Ship" name="Ship Order">
      <bpmn:incoming>Flow_Payment_Ship</bpmn:incoming>
      <bpmn:outgoing>Flow_Ship_Completed</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_Completed" name="Order completed">
      <bpmn:incoming>Flow_Ship_Completed</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Backordered" name="Backordered">
      <bpmn:incoming>Flow_Backorder_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Validate" sourceRef="StartEvent_OrderReceived" targetRef="Task_Validate" aio:animated="true" />
    <bpmn:sequenceFlow id="Flow_Validate_GWValid" sourceRef="Task_Validate" targetRef="Gateway_Valid" aio:animated="true" />
    <bpmn:sequenceFlow id="Flow_Valid_Reserve" name="yes" sourceRef="Gateway_Valid" targetRef="Task_Reserve" aio:animated="true" />
    <bpmn:sequenceFlow id="Flow_Valid_Rejected" name="no" sourceRef="Gateway_Valid" targetRef="EndEvent_Rejected" />
    <bpmn:sequenceFlow id="Flow_Reserve_GWStock" sourceRef="Task_Reserve" targetRef="Gateway_Stock" aio:animated="true" />
    <bpmn:sequenceFlow id="Flow_Stock_Payment" name="yes" sourceRef="Gateway_Stock" targetRef="Task_Payment" aio:animated="true" />
    <bpmn:sequenceFlow id="Flow_Stock_Backorder" name="no" sourceRef="Gateway_Stock" targetRef="Task_Backorder" />
    <bpmn:sequenceFlow id="Flow_Backorder_End" sourceRef="Task_Backorder" targetRef="EndEvent_Backordered" />
    <bpmn:sequenceFlow id="Flow_Payment_Ship" sourceRef="Task_Payment" targetRef="Task_Ship" aio:animated="true" />
    <bpmn:sequenceFlow id="Flow_Ship_Completed" sourceRef="Task_Ship" targetRef="EndEvent_Completed" aio:animated="true" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Group_12gj2fu_di" bpmnElement="Group_12gj2fu">
